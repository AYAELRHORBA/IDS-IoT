            ]
        ]
    },
    {
        "id": "89201c042fa5a725",
        "type": "function",
        "z": "27e938e05ed60cef",
        "name": "🔴 REJECT — DoS / Physical",
        "func": "msg.payload = msg.alert;\nmsg.topic   = 'attack';\nnode.status({fill:'red', shape:'ring', text:'🔴 REJECT — ' + msg.alert.label});\nnode.warn('🚨 ' + msg.alert.label + ' DÉTECTÉ sur ' + msg.alert.node_id + ' — ' + msg.alert.ip);\nreturn msg;",
        "outputs": 1,
        "x": 1430,
        "y": 440,
        "wires": [
            [
                "c704fd5015f018eb"
            ]
        ]
    },
    {
        "id": "b20917289ea8b7be",
        "type": "function",
        "z": "27e938e05ed60cef",
        "name": "🟠 QUARANTINE — Injection",
        "func": "msg.payload = msg.alert;\nmsg.topic   = 'attack';\nnode.status({fill:'orange', shape:'ring', text:'🟠 QUARANTINE — ' + msg.alert.label});\nnode.warn('⚠️ INJECTION sur ' + msg.alert.node_id + ' — données rejetées');\nreturn msg;",
        "outputs": 1,
        "x": 1430,
        "y": 500,
        "wires": [
            [
                "c704fd5015f018eb"
            ]
        ]
    },
    {
        "id": "4b58de0ca1ca2337",
        "type": "function",
        "z": "27e938e05ed60cef",
        "name": "🟡 WATCHLIST — Probe",
        "func": "msg.payload = msg.alert;\nmsg.topic   = 'attack';\nnode.status({fill:'yellow', shape:'dot', text:'🟡 WATCHLIST — ' + msg.alert.label});\nnode.warn('👁️ ' + msg.alert.label + ' détecté depuis ' + msg.alert.ip);\nreturn msg;",
        "outputs": 1,
        "x": 1410,
        "y": 580,
        "wires": [
            [
                "c704fd5015f018eb"
            ]
        ]
    },
    {
        "id": "c704fd5015f018eb",
        "type": "function",
        "z": "27e938e05ed60cef",
        "name": "Préparer sorties finales",
        "func": "const alert = msg.payload;\n\n// Recalculer directement ici — ne dépend plus des branches\nconst node_num = parseInt(\n    (alert.node_id || \"node_0\").replace(\"node_\", \"\")\n) || 0;\n\nconst attack_map = {\n    \"Normal\":             0,\n    \"DoS\":                1,\n    \"Injection_Frozen\":   2,\n    \"Injection_Aberrant\": 2,\n    \"Probe\":              3,\n    \"Physical\":           5\n};\n\nconst attack_code    = attack_map[alert.label] !== undefined\n                       ? attack_map[alert.label] : 3;\nconst confidence_pct = Math.round((alert.confidence || 0) * 100);\n\n// ── Sortie 1 → Flask + MQTT + Dashboard ──────────────────\nconst msg_out = {\n    payload: alert,\n    headers: {\"Content-Type\": \"application/json\"}\n};\n\n// ── Sortie 2 → ThingSpeak — UNIQUEMENT si attaque ────────\nlet msg_ts = null;\nif (alert.label !== \"Normal\") {\n    msg_ts = {\n        payload: {\n            field1: node_num,\n            field2: attack_code,\n            field3: confidence_pct\n        }\n    };\n}\n\nreturn [msg_out, msg_ts];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
