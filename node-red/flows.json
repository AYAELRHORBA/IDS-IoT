    {
        "id": "8963ce123b0f12d6",
        "type": "function",
        "z": "27e938e05ed60cef",
        "name": "Préparer body",
        "func": "if (typeof msg.payload === \"string\") {\n    msg.payload = JSON.parse(msg.payload);\n}\n\nconst d = msg.payload;\n\nconst ip_map = {\n    \"node_1\": \"192.168.1.10\",\n    \"node_2\": \"192.168.1.11\",\n    \"node_3\": \"192.168.1.12\",\n    \"node_4\": \"192.168.1.13\",\n    \"node_5\": \"192.168.1.14\"\n};\n\nmsg.payload = {\n    node_id:            d.node_id,\n    ip:                 d.ip || ip_map[d.node_id] || \"192.168.1.99\",\n    freq_msg_per_sec:   d.freq_msg_per_sec,\n    interval_ms:        d.interval_ms,\n    payload_size_bytes: d.payload_size_bytes,\n    payload_entropy:    d.payload_entropy,\n    nb_connexions:      d.nb_connexions\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
        "y": 480,
        "wires": [
            [
                "b095e0a4e33aec0d"
            ]
        ]
    },
    {
        "id": "742edba46232ae2d",
        "type": "function",
        "z": "27e938e05ed60cef",
        "name": "Logique décision",
        "func": "const ai = msg.payload;\n\nlet action, severity, attack_code;\n\nif (ai.label === 'Normal') {\n    action = 'ALLOW'; severity = 'OK'; attack_code = 0;\n}\nelse if (ai.label === 'DoS') {\n    action = 'REJECT'; severity = 'CRITICAL'; attack_code = 1;\n}\nelse if (ai.label === 'Injection_Frozen' || ai.label === 'Injection_Aberrant') {\n    action = 'QUARANTINE'; severity = 'DANGER'; attack_code = 2;\n}\nelse if (ai.label === 'Probe') {\n    action = 'WATCHLIST'; severity = 'WARNING'; attack_code = 3;\n}\nelse if (ai.label === 'Physical') {\n    action = 'REJECT'; severity = 'CRITICAL'; attack_code = 5;\n}\nelse {\n    action = 'WATCHLIST'; severity = 'WARNING'; attack_code = 3;\n}\n\nconst node_num = parseInt(ai.node_id.replace('node_', '')) || 0;\n\nmsg.action      = action;\nmsg.severity    = severity;\nmsg.attack_code = attack_code;\nmsg.node_num    = node_num;\n\nmsg.alert = {\n    label:      ai.label,\n    action:     action,\n    node_id:    ai.node_id,\n    ip:         ai.ip,\n    confidence: ai.confidence,\n    severity:   severity,\n    timestamp:  new Date().toISOString()\n};\n\nmsg.thingspeak = {\n    field1: node_num,\n    field2: attack_code,\n    field3: Math.round(ai.confidence * 100)\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 950,
        "y": 480,
        "wires": [
            [
                "c02169d8457e821b"
            ]
        ]
    },
