        "func": "const text = msg.payload || \"\";\n\n// Extraire le label depuis le texte formaté\nconst isNormal = text.includes(\"— Normal —\") || text.includes(\"] Normal —\");\n\ncontext.total   = (context.total   || 0) + 1;\ncontext.attacks = (context.attacks || 0) + (isNormal ? 0 : 1);\n\nconst taux = context.total > 0\n    ? Math.round(context.attacks / context.total * 100)\n    : 0;\n\nmsg.payload = \"Total : \" + context.total +\n              \" | Attaques : \" + context.attacks +\n              \" | Taux : \" + taux + \"%\";\n\nreturn msg;\n\n",
