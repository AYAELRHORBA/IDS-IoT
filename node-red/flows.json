    {
        "id": "eed6c936ead96a1d",
        "type": "function",
        "z": "27e938e05ed60cef",
        "name": "✅ ALLOW — Normal",
        "func": "msg.payload = msg.alert;\nmsg.topic   = 'normal';\nnode.status({fill:'green', shape:'dot', text:'Normal ✅'});\nreturn msg;",
        "outputs": 1,
        "x": 1400,
        "y": 360,
